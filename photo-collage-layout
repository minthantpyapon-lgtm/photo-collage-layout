<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Responsive Photo Editor</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        * { box-sizing: border-box; touch-action: none; margin: 0; padding: 0; }
        body { background: #121212; color: white; font-family: sans-serif; overflow: hidden; height: 100vh; width: 100vw; }
        
        /* Main Container setup for all screens */
        .main-container { display: flex; flex-direction: column; height: 100%; width: 100%; }

        /* Header */
        .header { padding: 8px; background: #1f1f1f; display: flex; flex-direction: column; gap: 6px; border-bottom: 1px solid #333; flex-shrink: 0; }
        .row { display: flex; justify-content: center; gap: 4px; flex-wrap: wrap; }
        button { padding: 8px 10px; background: #3d3d3d; color: white; border: none; border-radius: 6px; font-weight: bold; font-size: 10px; cursor: pointer; }
        .btn-before { background: #d9534f !important; }
        .btn-after { background: #5cb85c !important; }

        /* Color Bar */
        .color-bar { display: flex; justify-content: center; gap: 8px; padding: 6px; background: #262626; border-radius: 30px; margin: 2px 10px; }
        .c-btn { width: 24px; height: 24px; border-radius: 50%; border: 2px solid #555; }

        /* Flexible Editor View */
        .editor-view { 
            flex: 1; display: flex; flex-direction: column; 
            justify-content: center; align-items: center; 
            background: #000; position: relative; overflow: hidden; padding: 10px;
        }

        /* Fixed Ratio Square Grid */
        #collage-grid { 
            width: 92vw; height: 92vw; 
            max-width: 420px; max-height: 420px; 
            background: #222; display: grid; gap: 4px; border: 3px solid #fff; 
            position: relative; overflow: hidden; box-shadow: 0 0 20px rgba(0,0,0,0.5);
        }
        
        .slot { background-color: #333; background-size: cover; background-position: center; }

        /* Responsive Floating Text */
        .floating-text {
            position: absolute; left: 0; top: 0; padding: 10px;
            font-size: 30px; font-weight: 900; color: white;
            text-shadow: 2px 2px 5px rgba(0,0,0,0.9);
            white-space: nowrap; z-index: 100;
        }
        .floating-text.active { border: 2px dashed #007bff; background: rgba(0,123,255,0.1); border-radius: 4px; }

        /* Size Control Slider */
        .size-control { width: 100%; max-width: 350px; height: 50px; display: none; flex-direction: column; align-items: center; justify-content: center; margin-top: 5px; }
        .size-control input { width: 80%; height: 25px; accent-color: #007bff; }

        /* Footer */
        .footer { padding: 10px; background: #1f1f1f; display: flex; justify-content: center; gap: 10px; border-top: 1px solid #333; flex-shrink: 0; }
        .footer button { flex: 1; padding: 12px; font-size: 12px; }

        /* Layout Grid Areas */
        .grid-1 { grid-template-columns: 1fr; }
        .grid-2 { grid-template-columns: 1fr 1fr; }
        .grid-3 { grid-template-areas: "t t" "bl br"; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; }
        .grid-4 { grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; }
    </style>
</head>
<body>

<div class="main-container">
    <div class="header">
        <div class="row">
            <button onclick="undo()">UNDO</button>
            <button onclick="redo()">REDO</button>
            <button onclick="updateLayout('grid-1')">1P</button>
            <button onclick="updateLayout('grid-2')">2P</button>
            <button onclick="updateLayout('grid-3')">3P</button>
            <button onclick="updateLayout('grid-4')">4P</button>
        </div>
        <div class="row">
            <button class="btn-before" onclick="addFloatingText('BEFORE', '#ff3b30')">BEFORE</button>
            <button class="btn-after" onclick="addFloatingText('AFTER', '#4cd964')">AFTER</button>
        </div>
        <div class="color-bar">
            <div class="c-btn" style="background:#ffffff" onclick="applyColor('#ffffff')"></div>
            <div class="c-btn" style="background:#ff3b30" onclick="applyColor('#ff3b30')"></div>
            <div class="c-btn" style="background:#4cd964" onclick="applyColor('#4cd964')"></div>
            <div class="c-btn" style="background:#ffcc00" onclick="applyColor('#ffcc00')"></div>
            <div class="c-btn" style="background:#007bff" onclick="applyColor('#007bff')"></div>
        </div>
    </div>
    
    <div class="editor-view">
        <div id="collage-grid" class="grid-1"></div>
        
        <div class="size-control" id="sizeCtrl">
            <input type="range" id="sizeRange" min="10" max="150" value="30">
            <span style="font-size: 9px; margin-top: 2px;">Text Size</span>
        </div>
    </div>
    
    <div class="footer">
        <button style="background:#007bff;" onclick="showModal()">ADD TEXT</button>
        <button style="background:#28a745;" onclick="saveImage()">SAVE IMAGE</button>
    </div>
</div>

<div id="textModal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 2000; align-items: center; justify-content: center;">
    <div style="background: #2c2c2c; padding: 20px; border-radius: 12px; width: 85%; max-width: 300px; text-align: center;">
        <input type="text" id="txtInput" placeholder="Type" style="width: 100%; padding: 12px; margin-bottom: 15px; border-radius: 6px; background: #111; color: white; border: 1px solid #444; font-size: 16px;">
        <div class="row" style="gap: 10px;">
            <button style="background:#28a745; flex:1; padding: 12px;" onclick="createText()">ADD</button>
            <button style="background:#dc3545; flex:1; padding: 12px;" onclick="hideModal()">CANCEL</button>
        </div>
    </div>
</div>

<input type="file" id="fileInput" hidden accept="image/*">

<script>
    const grid = document.getElementById('collage-grid');
    const modal = document.getElementById('textModal');
    const sizeCtrl = document.getElementById('sizeCtrl');
    const sizeRange = document.getElementById('sizeRange');
    const txtInput = document.getElementById('txtInput');
    const fileInput = document.getElementById('fileInput');

    let history = [], step = -1;
    let selectedEl = null;

    function save() {
        step++;
        history = history.slice(0, step);
        history.push(grid.innerHTML);
    }

    function undo() {
        if (step > 0) { step--; grid.innerHTML = history[step]; attachEvents(); }
    }

    function redo() {
        if (step < history.length - 1) { step++; grid.innerHTML = history[step]; attachEvents(); }
    }

    function showModal() { modal.style.display = 'flex'; txtInput.focus(); }
    function hideModal() { modal.style.display = 'none'; }

    function createText() {
        const val = txtInput.value.trim();
        if (val) addFloatingText(val, '#ffffff');
        hideModal();
    }

    function addFloatingText(val, color) {
        const el = document.createElement('div');
        el.className = 'floating-text';
        el.innerText = val;
        el.style.color = color;
        // Start position relative to screen
        el.dataset.x = 20; el.dataset.y = 20; el.dataset.size = 30;
        el.style.transform = `translate(20px, 20px)`;
        grid.appendChild(el);
        makeDraggable(el);
        save();
    }

    function makeDraggable(el) {
        let startX, startY, initialX, initialY;
        
        el.addEventListener('touchstart', (e) => {
            e.stopPropagation();
            document.querySelectorAll('.floating-text').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            selectedEl = el;
            sizeCtrl.style.display = 'flex';
            sizeRange.value = el.dataset.size;
            
            if (e.touches.length === 1) {
                startX = e.touches[0].clientX;
                startY = e.touches[0].clientY;
                initialX = parseFloat(el.dataset.x);
                initialY = parseFloat(el.dataset.y);
            }
        });

        el.addEventListener('touchmove', (e) => {
            if (e.touches.length === 1 && selectedEl === el) {
                const dx = e.touches[0].clientX - startX;
                const dy = e.touches[0].clientY - startY;
                const nx = initialX + dx;
                const ny = initialY + dy;
                el.style.transform = `translate(${nx}px, ${ny}px)`;
                el.dataset.x = nx; el.dataset.y = ny;
            }
        });

        el.addEventListener('touchend', (e) => {
            if (e.timeStamp - (el.lastTap || 0) < 300) {
                el.remove(); sizeCtrl.style.display = 'none'; selectedEl = null;
            }
            el.lastTap = e.timeStamp;
            save();
        });
    }

    sizeRange.addEventListener('input', () => {
        if (selectedEl) {
            selectedEl.style.fontSize = `${sizeRange.value}px`;
            selectedEl.dataset.size = sizeRange.value;
        }
    });
    sizeRange.addEventListener('change', save);

    function applyColor(color) {
        if (selectedEl) { selectedEl.style.color = color; save(); }
    }

    function updateLayout(type) {
        const currentImgs = Array.from(document.querySelectorAll('.slot')).map(s => s.style.backgroundImage);
        grid.className = type;
        grid.innerHTML = '';
        const count = (type === 'grid-4') ? 4 : (type === 'grid-3' ? 3 : (type === 'grid-2' ? 2 : 1));
        
        for (let i = 0; i < count; i++) {
            const s = document.createElement('div');
            s.className = 'slot';
            if (currentImgs[i]) s.style.backgroundImage = currentImgs[i];
            s.onclick = () => {
                fileInput.onchange = (e) => {
                    if(!e.target.files[0]) return;
                    const reader = new FileReader();
                    reader.onload = (ev) => { s.style.backgroundImage = `url(${ev.target.result})`; save(); };
                    reader.readAsDataURL(e.target.files[0]);
                };
                fileInput.click();
            };
            if (type === 'grid-3') {
                if (i === 0) s.style.gridArea = "t";
                if (i === 1) s.style.gridArea = "bl";
                if (i === 2) s.style.gridArea = "br";
            }
            grid.appendChild(s);
        }
        save();
    }

    function attachEvents() {
        document.querySelectorAll('.floating-text').forEach(makeDraggable);
        document.querySelectorAll('.slot').forEach(s => {
            s.onclick = () => {
                fileInput.onchange = (e) => {
                    if(!e.target.files[0]) return;
                    const reader = new FileReader();
                    reader.onload = (ev) => { s.style.backgroundImage = `url(${ev.target.result})`; save(); };
                    reader.readAsDataURL(e.target.files[0]);
                };
                fileInput.click();
            };
        });
    }

    function saveImage() {
        document.querySelectorAll('.floating-text').forEach(t => t.classList.remove('active'));
        sizeCtrl.style.display = 'none';
        html2canvas(grid, { useCORS: true, scale: 2 }).then(canvas => {
            const a = document.createElement('a');
            a.download = 'edited_photo.png';
            a.href = canvas.toDataURL();
            a.click();
        });
    }

    window.onload = () => updateLayout('grid-1');
</script>
</body>
</html>
